# Buttondown API Key
# Get your API key from: https://buttondown.email/settings/programming
BUTTONDOWN_API_KEY=your_actual_buttondown_api_key_here

# Stripe
STRIPE_SECRET_KEY=sk_live_or_test_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_signing_secret_here

# Resend
RESEND_API_KEY=re_your_resend_api_key_here

# Analytics Dashboard Password
# Used to protect the /analytics endpoint in production
# Default: changeme123 (CHANGE THIS IN PRODUCTION!)
ANALYTICS_PASSWORD=your_secure_password_here
